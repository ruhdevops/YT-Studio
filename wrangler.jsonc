{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ytstudio",
  "compatibility_date": "2026-04-25",

  "main": "src/worker.ts",

  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },

  "d1_databases": [
    {
      "binding": "MY_DB",
      "database_name": "d1-machine-database",
      "database_id": "e36d3eba-7401-4945-b8e8-26cdbd13e3a9"
    }
  ],

  "compatibility_flags": [
    "nodejs_compat"
  ]
}
